---
interface Props {
    title: string;
    artist: string;
    releaseDate: string;
    coverSrc: string;
    coverSrc2x?: string;
}

const { title, artist, releaseDate, coverSrc, coverSrc2x } = Astro.props;

const date = new Date(releaseDate + 'T00:00:00');
const formattedDate = date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
});
---

<section class="upcoming-release">
    <div class="content">
        <p class="eyebrow">New single — coming {formattedDate}</p>
        <div class="release">
            <div class="cover-wrap">
                <img
                    class="cover"
                    src={coverSrc}
                    srcset={coverSrc2x ? `${coverSrc} 1x, ${coverSrc2x} 2x` : undefined}
                    alt={`${title} — album cover`}
                    loading="lazy"
                />
            </div>
            <div class="text">
                <h2 class="title">{title}</h2>
                <p class="artist">{artist}</p>
                <p class="date">
                    <span class="date-icon">◈</span>
                    {formattedDate}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .upcoming-release {
        padding: 2rem 2rem;
        display: flex;
        justify-content: center;
    }

    .content {
        max-width: 600px;
        width: 100%;
    }

    .eyebrow {
        text-align: center;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ctp-mauve);
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }

    .release {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1.5rem;
        background-color: var(--ctp-surface0);
        border: 2px solid var(--ctp-mauve);
        border-radius: 16px;
        transition: transform 0.3s ease;
    }

    .release:hover {
        transform: translateY(-4px);
    }

    .cover-wrap {
        flex-shrink: 0;
        position: relative;
    }

    .cover {
        width: 180px;
        height: 180px;
        border-radius: 8px;
        display: block;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .text {
        flex: 1;
        min-width: 0;
    }

    .title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--ctp-text);
        margin: 0 0 0.4rem;
        line-height: 1.2;
    }

    .artist {
        font-size: 1rem;
        color: var(--ctp-subtext0);
        margin: 0 0 1rem;
    }

    .date {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--ctp-mauve);
        margin: 0;
    }

    .date-icon {
        color: var(--ctp-mauve);
    }

    @media (max-width: 600px) {
        .upcoming-release {
            padding: 1.5rem 2rem;
        }

        .release {
            flex-direction: column;
            text-align: center;
            gap: 1.5rem;
            padding: 1.5rem;
        }

        .cover {
            width: 200px;
            height: 200px;
        }

        .title {
            font-size: 1.35rem;
        }

        .date {
            justify-content: center;
        }
    }
</style>
