---
type Release = {
    date: string;
    title: string;
    youtubeId: string;
};

const releases: Record<string, Release[]> = {
    '2026': [
        { date: '2026-05-27', title: 'know nothing (may 2026 demo)', youtubeId: 'D4aOTEZN9Sk' },
        { date: '2026-05-02', title: 'phoenix inside (april 2026 demo)', youtubeId: 'uID9bNYEoDs' }
    ],
    '2025': [
        { date: '2025-12-24', title: 'tiny christmas tree (demo)', youtubeId: 'vHfMDwIj4Vs' },
        { date: '2025-12-01', title: 'dying star memories (demo)', youtubeId: 'pudP6_Tu8Vc' },
        { date: '2025-10-29', title: 'friend of the lonely (demo)', youtubeId: 'dYyjhffh6dI' },
        { date: '2025-09-24', title: 'nothing in my pockets (demo)', youtubeId: 'dHX4q6ZjDRw' },
        { date: '2025-08-25', title: 'feels like yesterday — ft. Ó Caiside (demo)', youtubeId: 'Q9QwCnA9Jwc' },
        { date: '2025-08-04', title: 'midnight text — ft. Ó Caiside (demo)', youtubeId: '-8p6pnwVk5U' },
        { date: '2025-07-01', title: 'sooner or later — ft. Ó Caiside (demo)', youtubeId: '_MEoR2RiJx0' },
        { date: '2025-06-30', title: 'phase (demo)', youtubeId: 'dtFxEQda3MU' },
        { date: '2025-06-29', title: 'extra lives 愛してる (demo)', youtubeId: '_hvgGIh3cH4' },
        { date: '2025-05-21', title: 'abstract biology (demo)', youtubeId: 'iYnAyQLofdE' },
        { date: '2025-04-15', title: 'again (demo)', youtubeId: 'YiIzpPTNZ5E' },
        { date: '2025-03-31', title: 'distance 新しい道理 (demo)', youtubeId: 'dgXyEc-YTNs' }
    ]
};

const years = Object.keys(releases).sort((a, b) => Number(b) - Number(a));

const formatMMDD = (iso: string) => iso.slice(5);
---

<section class="release-archive">
    <div class="content">
        <h2 class="section-title">All Releases</h2>
        {
            years.map((year) => (
                <details class="year">
                    <summary class="year-summary">
                        <span class="chev" aria-hidden="true">›</span>
                        <span class="year-label">{year}</span>
                        <span class="year-count">{releases[year].length} release{releases[year].length === 1 ? '' : 's'}</span>
                    </summary>
                    <ul class="release-list">
                        {releases[year]
                            .slice()
                            .sort((a, b) => b.date.localeCompare(a.date))
                            .map((r) => (
                                <li>
                                    <a class="release-link" href={`https://www.youtube.com/watch?v=${r.youtubeId}`} target="_blank" rel="noopener noreferrer">
                                        <span class="release-date">{formatMMDD(r.date)}</span>
                                        <span class="release-title">{r.title}</span>
                                    </a>
                                </li>
                            ))}
                    </ul>
                </details>
            ))
        }
    </div>
</section>

<style>
    .release-archive {
        padding: 1rem 2rem;
        display: flex;
        justify-content: center;
    }

    .content {
        max-width: 600px;
        width: 100%;
    }

    .section-title {
        text-align: center;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ctp-mauve);
        margin: 0 0 1.5rem;
        opacity: 0.9;
    }

    .year {
        border-top: 1px solid var(--ctp-surface1);
    }

    .year:last-of-type {
        border-bottom: 1px solid var(--ctp-surface1);
    }

    .year-summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        padding: 0.6rem 0.25rem;
        color: var(--ctp-text);
        font-size: 1rem;
        user-select: none;
        transition: color 0.2s ease;
    }

    .year-summary::-webkit-details-marker {
        display: none;
    }

    .year-summary:hover {
        color: var(--ctp-mauve);
    }

    .chev {
        display: inline-block;
        font-size: 1.1rem;
        color: var(--ctp-overlay1);
        transition: transform 0.2s ease, color 0.2s ease;
        line-height: 1;
        transform: translateY(1px);
    }

    .year[open] > .year-summary .chev {
        transform: rotate(90deg) translateX(1px);
        color: var(--ctp-mauve);
    }

    .year-label {
        font-weight: 600;
        letter-spacing: 0.02em;
        flex: 1;
    }

    .year-count {
        font-size: 0.8rem;
        color: var(--ctp-overlay1);
        font-variant-numeric: tabular-nums;
    }

    .release-list {
        list-style: none;
        margin: 0;
        padding: 0 0 0.5rem 1.6rem;
    }

    .release-list li {
        margin: 0;
    }

    .release-link {
        display: flex;
        align-items: baseline;
        gap: 0.85rem;
        padding: 0.3rem 0.25rem;
        color: var(--ctp-subtext0);
        text-decoration: none;
        font-size: 0.9rem;
        line-height: 1.4;
        border-radius: 4px;
        transition: color 0.15s ease, background-color 0.15s ease;
    }

    .release-link:hover,
    .release-link:focus-visible {
        color: var(--ctp-text);
        background-color: var(--ctp-surface0);
    }

    .release-date {
        font-variant-numeric: tabular-nums;
        color: var(--ctp-overlay1);
        font-size: 0.8rem;
        letter-spacing: 0.02em;
        flex-shrink: 0;
        min-width: 3.25rem;
    }

    .release-link:hover .release-date {
        color: var(--ctp-mauve);
    }

    .release-title {
        flex: 1;
    }

    @media (max-width: 600px) {
        .release-archive {
            padding: 0.75rem 1.5rem;
        }

        .section-title {
            font-size: 0.8rem;
            margin: 0 0 1rem;
        }

        .year-summary {
            font-size: 0.95rem;
        }

        .release-link {
            font-size: 0.85rem;
            gap: 0.65rem;
        }
    }
</style>
