---
interface Props {
    color: string;
    speed?: number;
    size?: number;
    direction?: 'left' | 'right';
}

const { color, speed = 6, direction = 'left' } = Astro.props;

const colorMap: Record<string, string> = {
    rosewater: 'var(--ctp-rosewater)',
    flamingo: 'var(--ctp-flamingo)',
    pink: 'var(--ctp-pink)',
    mauve: 'var(--ctp-mauve)',
    red: 'var(--ctp-red)',
    maroon: 'var(--ctp-maroon)',
    peach: 'var(--ctp-peach)',
    yellow: 'var(--ctp-yellow)',
    green: 'var(--ctp-green)',
    teal: 'var(--ctp-teal)',
    sky: 'var(--ctp-sky)',
    sapphire: 'var(--ctp-sapphire)',
    blue: 'var(--ctp-blue)',
    lavender: 'var(--ctp-lavender)'
};

const accent = colorMap[color] ?? 'var(--ctp-mauve)';
const animationClass = direction === 'left' ? 'flow-left' : 'flow-right';
---

<div class="divider-container">
    <div
        class:list={['divider', animationClass]}
        style={`--accent: ${accent}; --flow-speed: ${speed}s;`}
    >
    </div>
</div>

<style>
    .divider-container {
        width: 100%;
        padding: 0.75rem 2rem;
        display: flex;
        justify-content: center;
    }

    .divider {
        width: 100%;
        max-width: 600px;
        height: 2px;
        border-radius: 2px;
        background-image: linear-gradient(
            90deg,
            transparent 0%,
            var(--ctp-mauve) 20%,
            var(--accent) 50%,
            var(--ctp-blue) 80%,
            transparent 100%
        );
        background-size: 200% 100%;
        background-repeat: repeat-x;
        box-shadow: 0 0 12px color-mix(in srgb, var(--accent) 50%, transparent);
        mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
        -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    }

    .flow-left {
        animation: flow-left var(--flow-speed) linear infinite;
    }

    .flow-right {
        animation: flow-right var(--flow-speed) linear infinite;
    }

    @keyframes flow-left {
        from {
            background-position: 200% 0%;
        }
        to {
            background-position: 0% 0%;
        }
    }

    @keyframes flow-right {
        from {
            background-position: 0% 0%;
        }
        to {
            background-position: 200% 0%;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .flow-left,
        .flow-right {
            animation: none;
        }
    }

    @media (max-width: 600px) {
        .divider-container {
            padding: 0.5rem 1rem;
        }
    }
</style>
