---
interface Props {
    title: string;
    artist: string;
    releaseDate: string;
    youtubeId: string;
}

const { title, artist, releaseDate, youtubeId } = Astro.props;

const date = new Date(releaseDate + 'T00:00:00');
const formattedDate = date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
});

const embedUrl = `https://www.youtube-nocookie.com/embed/${youtubeId}`;
---

<section class="latest-release">
    <div class="content">
        <p class="eyebrow">Latest release — out {formattedDate}</p>
        <div class="release">
            <div class="video-wrap">
                <iframe
                    class="video"
                    src={embedUrl}
                    title={`${title} — ${artist}`}
                    loading="lazy"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                ></iframe>
            </div>
            <div class="text">
                <h2 class="title">{title}</h2>
                <p class="artist">{artist}</p>
                <p class="date">
                    <span class="date-icon">◈</span>
                    {formattedDate}
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .latest-release {
        padding: 2rem 2rem;
        display: flex;
        justify-content: center;
    }

    .content {
        max-width: 600px;
        width: 100%;
    }

    .eyebrow {
        text-align: center;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ctp-blue);
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }

    .release {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        padding: 1.5rem;
        background-color: var(--ctp-surface0);
        border: 2px solid var(--ctp-blue);
        border-radius: 16px;
        transition: transform 0.3s ease;
    }

    .release:hover {
        transform: translateY(-4px);
    }

    .video-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        background-color: #000;
    }

    .video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    .text {
        flex: 1;
        min-width: 0;
    }

    .title {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--ctp-text);
        margin: 0 0 0.4rem;
        line-height: 1.2;
    }

    .artist {
        font-size: 1rem;
        color: var(--ctp-subtext0);
        margin: 0 0 1rem;
    }

    .date {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--ctp-blue);
        margin: 0;
    }

    .date-icon {
        color: var(--ctp-blue);
    }

    @media (max-width: 600px) {
        .latest-release {
            padding: 1.5rem 2rem;
        }

        .release {
            padding: 1.25rem;
            gap: 1rem;
        }

        .title {
            font-size: 1.35rem;
        }
    }
</style>
